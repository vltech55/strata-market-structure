# ──────────────────────────────────────────────────────────────────────────────
# Strata — environment configuration
# Copy to `.env` and fill in real values for any non-default deployment.
# Settings are loaded via pydantic-settings in `backend/strata/settings.py`.
# ──────────────────────────────────────────────────────────────────────────────

# Environment ─────────────────────────────────────────────────────────────────
ENV=development                  # development | staging | production
DEBUG=true                       # MUST be false in staging/production
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string

ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:8501
CORS_ALLOWED_ORIGINS=http://localhost:8501

# Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://strata:strata@postgres:5432/strata
DB_CONN_MAX_AGE=60
DB_POOL_MIN_SIZE=4
DB_POOL_MAX_SIZE=20

POSTGRES_DB=strata
POSTGRES_USER=strata
POSTGRES_PASSWORD=strata

# Redis / Celery ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_QUEUE=strata.default
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Object storage (MinIO / S3) ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=strata
MINIO_SECURE=false

# JWT RS256 ────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/app/keys/jwt-rs256-private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt-rs256-public.pem
JWT_ISSUER=strata
JWT_ACCESS_TTL_SECONDS=900            # 15 min
JWT_REFRESH_TTL_SECONDS=2592000       # 30 days
JWT_ALGORITHM=RS256

# OpenAI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1200

# Langfuse (LLM tracing) ───────────────────────────────────────────────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT=strata

# Bybit (public REST — no key needed for OHLCV) ────────────────────────────────
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_CATEGORY=linear              # linear | spot | inverse
BYBIT_REQUEST_TIMEOUT=20

# Observability ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=strata-backend
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json | console

# Streamlit frontend ───────────────────────────────────────────────────────────
STRATA_API_URL=http://backend:8000/api
STRATA_BROWSER_API_URL=http://localhost:8000/api
